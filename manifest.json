/* ============================================
   EVIDENCE - Service Worker Registration
   Versão: 1.0.0
   ============================================ */

(function() {
    'use strict';

    class ServiceWorkerManager {
        constructor() {
            this.registration = null;
            this.isSupported = 'serviceWorker' in navigator;
            this.isRegistered = false;
            this.updateInterval = null;
            this.autoUpdateInterval = 3600000; // 1 hour

            if (this.isSupported) {
                this.register();
                this.setupUpdateCheck();
            } else {
                console.log('⚠️ Service Workers not supported');
            }
        }

        /**
         * Register service worker
         */
        async register() {
            try {
                this.registration = await navigator.serviceWorker.register('/service-worker.js', {
                    scope: '/'
                });

                this.isRegistered = true;
                console.log('✅ Service Worker registered');

                // Check for updates
                this.checkForUpdates();

                // Listen for updates
                this.registration.addEventListener('updatefound', () => {
                    const newWorker = this.registration.installing;
                    console.log('🔄 Service Worker update found');

                    newWorker.addEventListener('statechange', () => {
                        if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                            console.log('✅ New Service Worker installed');
                            this.showUpdateNotification();
                        }
                    });
                });

                return this.registration;
            } catch (error) {
                console.error('❌ Service Worker registration failed:', error);
                return null;
            }
        }

        /**
         * Check for updates
         */
        async checkForUpdates() {
            if (!this.registration) return;

            try {
                await this.registration.update();
                console.log('🔍 Service Worker update check completed');
            } catch (error) {
                console.error('❌ Service Worker update check failed:', error);
            }
        }

        /**
         * Setup automatic update check
         */
        setupUpdateCheck() {
            if (this.updateInterval) {
                clearInterval(this.updateInterval);
            }

            this.updateInterval = setInterval(() => {
                if (this.registration) {
                    this.checkForUpdates();
                }
            }, this.autoUpdateInterval);
        }

        /**
         * Show update notification
         */
        showUpdateNotification() {
            // Check if we have a notification system
            if (window.Components && window.Components.Toast) {
                Components.Toast({
                    message: '🔄 Nova atualização disponível! Clique para atualizar.',
                    type: 'info',
                    duration: 10000,
                    onClose: () => {
                        this.skipWaiting();
                    }
                });
            } else {
                // Fallback notification
                const update = confirm('🔄 Nova versão disponível! Atualizar agora?');
                if (update) {
                    this.skipWaiting();
                }
            }
        }

        /**
         * Skip waiting and activate new worker
         */
        async skipWaiting() {
            if (!this.registration) return;

            try {
                const waiting = this.registration.waiting;
                if (waiting) {
                    waiting.postMessage({ type: 'SKIP_WAITING' });
                    window.location.reload();
                }
            } catch (error) {
                console.error('❌ Skip waiting failed:', error);
            }
        }

        /**
         * Get registration status
         */
        getStatus() {
            if (!this.isSupported) {
                return {
                    supported: false,
                    registered: false,
                    status: 'unsupported'
                };
            }

            if (!this.registration) {
                return {
                    supported: true,
                    registered: false,
                    status: 'pending'
                };
            }

            const states = {
                'installing': '⏳ Instalando...',
                'installed': '✅ Instalado',
                'activating': '⏳ Ativando...',
                'activated': '✅ Ativo',
                'redundant': '❌ Redundante'
            };

            const state = this.registration.active?.state || 'pending';

            return {
                supported: true,
                registered: this.isRegistered,
                status: state,
                statusText: states[state] || 'Desconhecido',
                scope: this.registration.scope,
                activeWorker: this.registration.active
            };
        }

        /**
         * Clear cache
         */
        async clearCache() {
            if (!this.registration) return;

            return new Promise((resolve) => {
                const channel = new MessageChannel();
                channel.port1.onmessage = (event) => {
                    resolve(event.data);
                };

                if (this.registration.active) {
                    this.registration.active.postMessage({
                        type: 'CLEAR_CACHE'
                    }, [channel.port2]);
                } else {
                    resolve({ success: false, error: 'No active worker' });
                }
            });
        }

        /**
         * Cache additional URLs
         */
        async cacheUrls(urls) {
            if (!this.registration) return;

            return new Promise((resolve) => {
                const channel = new MessageChannel();
                channel.port1.onmessage = (event) => {
                    resolve(event.data);
                };

                if (this.registration.active) {
                    this.registration.active.postMessage({
                        type: 'CACHE_URLS',
                        urls: urls
                    }, [channel.port2]);
                } else {
                    resolve({ success: false, error: 'No active worker' });
                }
            });
        }

        /**
         * Unregister service worker
         */
        async unregister() {
            if (!this.registration) return;

            try {
                const result = await this.registration.unregister();
                if (result) {
                    console.log('🗑️ Service Worker unregistered');
                    this.isRegistered = false;
                    this.registration = null;
                }
                return result;
            } catch (error) {
                console.error('❌ Service Worker unregister failed:', error);
                return false;
            }
        }
    }

    // ============================================
    // AUTO-INIT
    // ============================================

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initServiceWorker);
    } else {
        initServiceWorker();
    }

    function initServiceWorker() {
        // Only register in production
        if (window.location.hostname !== 'localhost' && !window.location.hostname.includes('127.0.0.1')) {
            window.swManager = new ServiceWorkerManager();
        } else {
            console.log('🔧 Service Worker: Development mode - skipping registration');
        }
    }

    // ============================================
    // EXPORT
    // ============================================

    if (typeof window !== 'undefined') {
        window.ServiceWorkerManager = ServiceWorkerManager;
    }

    if (typeof module !== 'undefined' && module.exports) {
        module.exports = { ServiceWorkerManager };
    }

    console.log('📱 Evidence - Service Worker Manager Loaded');

})();